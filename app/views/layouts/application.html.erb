<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <%= stylesheet_link_tag "application" %>
  </head>
  <body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="navbar-brand ms-3">
        <a class="navbar-brand" href="/places">Home</a>
      </div>
      <div class="ms-auto me-3">
        <% current_user = User.find_by({ "id" => session["user_id"] }) %>
        <% if current_user.present? %>
          <span class="text-white me-3">Logged in as: <%= current_user["username"] %></span>
          <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
        <% else %>
          <a class="btn btn-outline-light btn-sm me-2" href="/login">Login</a>
          <a class="btn btn-outline-light btn-sm" href="/signup">Signup</a>
        <% end %>
      </div>
    </nav>

    <div class="container mt-4">
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>